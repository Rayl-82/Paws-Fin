generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- USER & AUTHENTICATION ---
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())

  totalWasteDivertedKg Float @default(0)
  averageImpactScore   Float @default(0)

  // Relationships (Required for Prisma mapping)
  pets           Pet[]
  orders         Order[]
  subscriptions  Subscription[]
  cartItems      CartItem[]
  partnerProfile PartnerProfile?
}

enum Role {
  CUSTOMER
  ADMIN
  PARTNER
}

// --- PET PROFILES ---
model Pet {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  petName         String
  species         String
  breed           String?
  age             Int?
  weight          Float?
  activityLevel   String?
  healthCondition String?

  createdAt DateTime @default(now())
}

// --- E-COMMERCE: PRODUCTS ---
model Product {
  id              String   @id @default(uuid())
  name            String
  description     String
  price           Float
  stock           Int      @default(0)
  imageUrl        String?
  category        String?
  features        String[] // E.g., benefits for subscriptions or bundles
  billingInterval String? // E.g., "MONTHLY" for subscriptions

  // Impact Engine Fields
  weightGram           Int             @default(0)
  fishByProductPercent Float           @default(0)
  yieldConversion      Float           @default(1.0)
  baseImpactScore      Float           @default(0)
  partnerId            String?
  partner              PartnerProfile? @relation(fields: [partnerId], references: [id])

  createdAt DateTime @default(now())

  // Relationships (Required for Prisma mapping)
  orderItems OrderItem[]
  cartItems  CartItem[]
}

// --- SHOPPING CART ---
model CartItem {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
}

// --- ORDERS & CHECKOUT ---
model Order {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalPrice      Float
  status          String   @default("PENDING")
  shippingAddress String?
  notes           String?
  createdAt       DateTime @default(now())

  // Relationships
  orderItems OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float // Price at time of purchase

  // Impact Engine Fields
  wasteDivertedKg Float   @default(0)
  impactScore     Float   @default(0)
  partnerId       String?
}

// --- ACTIVE USER SUBSCRIPTIONS ---
model Subscription {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planName     String
  status       String    @default("ACTIVE")
  startDate    DateTime  @default(now())
  nextDelivery DateTime?
}

// --- PARTNER & SUPPLIER PORTAL ---
model PartnerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  industryType    String
  isVerified      Boolean  @default(false)
  totalIncome     Float    @default(0)
  co2SavedKg      Float    @default(0)
  wasteRepurposed Float    @default(0)
  createdAt       DateTime @default(now())

  inventory InventoryItem[]
  requests  PartnerRequest[]
  products  Product[]
}

model InventoryItem {
  id        String         @id @default(uuid())
  partnerId String
  partner   PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name      String
  stockInKg Float
  status    String         @default("Tersedia") // "Tersedia", "Habis"
  updatedAt DateTime       @updatedAt
}

model PartnerRequest {
  id               String         @id @default(uuid())
  partnerId        String
  partner          PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  umkmName         String
  productRequested String
  quantityInKg     Float
  status           String         @default("Menunggu Konfirmasi") // "Menunggu Konfirmasi", "Disetujui", "Dikirim"
  createdAt        DateTime       @default(now())
}
